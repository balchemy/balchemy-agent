  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@balchemyai/agent-sdk": "^0.1.1",
    "@inkjs/ui": "^2.0.0",
    "dotenv": "^16.0.0",
    "ink": "^6.0.0",
    "js-yaml": "^4.1.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "22.17.2",
    "@types/react": "^19.0.0",
    "typescript": "5.8.3"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
