# Balchemy Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Required ──────────────────────────────────────────────────────────────────

# Your Balchemy MCP endpoint (Hub > Agents > your agent > API tab)
MCP_ENDPOINT=https://api.balchemy.ai/mcp/YOUR_PUBLIC_ID

# Your Balchemy API key (Hub > Agents > your agent > API Keys)
BALCHEMY_API_KEY=balc_your_api_key_here

# LLM provider API key (Anthropic or OpenAI)
LLM_API_KEY=sk-ant-your-key-here

# ─── Optional ──────────────────────────────────────────────────────────────────

# Webhook HMAC secret (only if webhook.port is set in agent.config.yaml)
# WEBHOOK_SECRET=your_32_char_minimum_secret_here
